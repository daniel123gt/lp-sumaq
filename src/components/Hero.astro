---
---

<section id="inicio" class="hero">
  <div class="hero-carousel">
    <div class="carousel-slide active" style="background-image: url('/hero/hero1.jpg')"></div>
    <div class="carousel-slide" style="background-image: url('/hero/hero2.jpg')"></div>
    <div class="carousel-slide" style="background-image: url('/hero/hero3.jpg')"></div>
    <div class="carousel-slide" style="background-image: url('/hero/hero4.jpg')"></div>

    <div class="overlay"></div>
  </div>

  <div class="hero-inner">
    <div class="hero-content">
      <h1 class="hero-title">Honramos a la madre Naturaleza</h1>
      <p class="hero-subtitle">y transformamos su belleza en propósito</p>

      <div class="hero-actions">
        <a href="/productos" class="btn btn-hero-secondary">Conoce nuestros productos</a>
        <a href="/contacto" class="btn btn-hero-secondary">Contáctanos</a>
      </div>
    </div>

    <img class="hero-logo" src="/logo-white.svg" alt="SUMAQ AGRO" width="140" height="140" />
  </div>

  <div class="carousel-indicators">
    <button class="indicator active" data-slide="0" aria-label="Ir a la imagen 1"></button>
    <button class="indicator" data-slide="1" aria-label="Ir a la imagen 2"></button>
    <button class="indicator" data-slide="2" aria-label="Ir a la imagen 3"></button>
    <button class="indicator" data-slide="3" aria-label="Ir a la imagen 4"></button>
  </div>
</section>

<style>
  .hero {
    position: relative;
    min-height: 100vh;
    overflow: hidden;
    padding-top: 95px;
  }

  .hero-carousel {
    position: absolute;
    inset: 0;
    overflow: hidden;
  }

  .carousel-slide {
    position: absolute;
    inset: 0;
    background-size: cover;
    background-position: center;
    background-repeat: no-repeat;
    opacity: 0;
    transition: opacity 1s ease-in-out;
  }

  .carousel-slide.active {
    opacity: 1;
  }

  .overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      180deg,
      rgba(0, 0, 0, 0.35) 0%,
      rgba(0, 0, 0, 0.25) 40%,
      rgba(0, 0, 0, 0.45) 100%
    );
    z-index: 1;
  }

  .hero-inner {
    position: relative;
    z-index: 2;
    max-width: 1400px;
    margin: 0 auto;
    padding: 4rem 3rem 6rem;
    min-height: calc(100vh - 95px);
    display: flex;
    flex-direction: column;
    justify-content: space-between;
  }

  .hero-content {
    max-width: 1280px;
    padding-top: 6rem;
  }

  .hero-title {
    font-family: "Adelle", Georgia, serif;
    font-size: clamp(2.4rem, 5.2vw, 4rem);
    font-weight: 700;
    line-height: 1.1;
    color: #ffffff;
    text-shadow: 0 2px 12px rgba(0, 0, 0, 0.45);
  }

  .hero-subtitle {
    font-family: "Adelle", Georgia, serif;
    font-size: clamp(1.2rem, 2.2vw, 1.75rem);
    font-weight: 400;
    line-height: 1.3;
    color: #ffffff;
    margin: 0 0 2.5rem 0;
    text-shadow: 0 2px 10px rgba(0, 0, 0, 0.45);
  }

  .hero-actions {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .btn-hero-primary,
  .btn-hero-secondary {
    font-family: "Adelle", Georgia, serif;
    display: inline-block;
    padding: 0.85rem 1.75rem;
    border-radius: 12px;
    text-decoration: none;
    font-weight: 600;
    font-size: 1rem;
    transition: all 0.25s ease;
    cursor: pointer;
    text-align: center;
    background-color: #293d1a;
    width: 270px;
  }

  .btn-hero-primary {
    background: #425C25;
    color: #ffffff;
    border-color: rgba(255, 255, 255, 0.25);
  }

  .btn-hero-primary:hover {
    background: #3a5220;
    transform: translateY(-2px);
    box-shadow: 0 8px 20px rgba(0, 0, 0, 0.25);
  }

  .btn-hero-secondary {
    background: #32411C;
    color: #ffffff;
  }

  .btn-hero-secondary:hover {
    background: #283515;
    transform: translateY(-2px);
    box-shadow: 0 8px 20px rgba(0, 0, 0, 0.25);
  }

  .hero-logo {
    align-self: flex-end;
    width: clamp(90px, 11vw, 140px);
    height: auto;
    filter: drop-shadow(0 2px 10px rgba(0, 0, 0, 0.35));
    user-select: none;
  }

  .carousel-indicators {
    position: absolute;
    bottom: 1.5rem;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    gap: 0.75rem;
    z-index: 3;
  }

  .indicator {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    border: 1.5px solid rgba(255, 255, 255, 0.7);
    background: transparent;
    cursor: pointer;
    padding: 0;
    transition: all 0.25s ease;
  }

  .indicator.active {
    background: #ffffff;
    border-color: #ffffff;
  }

  .indicator:hover {
    background: rgba(255, 255, 255, 0.6);
  }

  @media (max-width: 768px) {
    .hero-inner {
      padding: 2.5rem 1.5rem 5rem;
    }

    .hero-content {
      max-width: 100%;
    }

    .hero-actions {
      gap: 0.75rem;
    }

    .btn-hero-primary,
    .btn-hero-secondary {
      padding: 0.75rem 1.25rem;
      font-size: 0.95rem;
    }

    .hero-logo {
      align-self: flex-end;
      margin-top: 2rem;
    }

    .carousel-indicators {
      bottom: 1rem;
    }
  }
</style>

<script>
  let carouselInterval: ReturnType<typeof setTimeout> | null = null;
  let currentSlideIndex = 0;

  function initHeroCarousel() {
    const slides = document.querySelectorAll<HTMLElement>('.carousel-slide');
    const indicators = document.querySelectorAll<HTMLButtonElement>('.indicator');

    if (slides.length === 0) return;

    if (carouselInterval) {
      clearTimeout(carouselInterval);
      carouselInterval = null;
    }

    currentSlideIndex = 0;
    slides.forEach((slide, index) => {
      if (slide.classList.contains('active')) {
        currentSlideIndex = index;
      }
    });

    function showSlide(index: number) {
      slides.forEach(slide => slide.classList.remove('active'));
      indicators.forEach(indicator => indicator.classList.remove('active'));

      slides[index].classList.add('active');
      indicators[index].classList.add('active');

      currentSlideIndex = index;
    }

    function nextSlide() {
      const nextIndex = (currentSlideIndex + 1) % slides.length;
      showSlide(nextIndex);
    }

    function startCarousel() {
      carouselInterval = setTimeout(() => {
        nextSlide();
        startCarousel();
      }, 5000);
    }

    function stopCarousel() {
      if (carouselInterval) {
        clearTimeout(carouselInterval);
        carouselInterval = null;
      }
    }

    indicators.forEach((indicator, index: number) => {
      indicator.addEventListener('click', () => {
        showSlide(index);
        stopCarousel();
        startCarousel();
      });
    });

    const hero = document.querySelector<HTMLElement>('.hero');
    if (hero) {
      hero.addEventListener('mouseenter', stopCarousel);
      hero.addEventListener('mouseleave', startCarousel);
    }

    showSlide(currentSlideIndex);

    startCarousel();
  }

  document.addEventListener('DOMContentLoaded', initHeroCarousel);

  document.addEventListener('astro:page-load', initHeroCarousel);
</script>
