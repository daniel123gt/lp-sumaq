          <li><a href="/contacto">Contacto</a></li>
        </ul>
      </div>

      <div class="footer-section footer-contact">
        <h4>CONTACTO</h4>
        <ul class="footer-contact-list">
          <li class="footer-contact-card">+51 982711622</li>
          <li class="footer-contact-card">comercial@sumaqagro.pe</li>
          <li class="footer-contact-card">sgomez@sumaqagro.pe</li>
        </ul>
        <a href="/contacto" class="footer-cta-btn">Contáctanos</a>
