    </div>

    <div class="footer-bottom">
      <div class="footer-bottom-content">
        <p class="copyright">&copy; 2025 SUMAQ AGRO. Todos los derechos reservados.</p>
        <div class="legal-links">
          <a href="#">Política de Privacidad</a>
          <a href="#">Términos de servicios</a>
          <a href="#">Política de cookies</a>
        </div>
      </div>
    </div>
  </div>
</footer>

<style>
  .footer {
    background: #ffffff;
    color: var(--color-dark, #32411C);
    padding: 4rem 0 0 0;
  }

  .container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 2rem;
  }

  .footer-content {
    display: grid;
    grid-template-columns: 1.6fr 1fr 1fr 1fr 1.1fr;
    gap: 2.5rem;
    margin-bottom: 3rem;
  }

  .footer-section h4 {
    font-size: 1rem;
    font-weight: 700;
    margin-bottom: 1.5rem;
    color: #2c4a1a;
    letter-spacing: 0.04em;
  }

  .footer-brand {
    max-width: 320px;
  }

  .footer-logo {
    margin-bottom: 1.25rem;
  }

  .footer-logo-link {
    display: inline-block;
    text-decoration: none;
  }

  .footer-logo-image {
    height: auto;
    width: 120px;
    max-width: 100%;
  }

  .footer-description {
    color: #995924;
    line-height: 1.55;
    margin-bottom: 1.5rem;
    font-size: 0.92rem;
  }

  .social-links {
    display: flex;
    gap: 0.75rem;
    align-items: center;
  }

  .social-link {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    text-decoration: none;
    transition: transform 0.25s ease;
  }

  .social-link img {
    width: 32px;
    height: 32px;
    display: block;
  }

  .social-link:hover {
    transform: translateY(-2px);
  }

  .footer-links {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .footer-links li {
    margin-bottom: 0.6rem;
  }

  .footer-links a {
    color: #3d4920;
    text-decoration: none;
    transition: color 0.25s ease;
    font-size: 0.92rem;
    font-weight: 400;
  }

  .footer-links a:hover {
    color: #2c4a1a;
  }

  .footer-contact-list {
    list-style: none;
    padding: 0;
    margin: 0 0 1.5rem 0;
    display: flex;
    flex-direction: column;
    gap: 0.85rem;
  }

  .footer-contact-card {
    background: #ffffff;
    border: none;
    border-radius: 10px;
    padding: 0.95rem 1.25rem;
    color: #9F5818;
    font-weight: 600;
    font-size: 0.88rem;
    box-shadow: none;
  }

  .footer-cta-btn {
    display: block;
    width: 100%;
    background: linear-gradient(135deg, #9F5818 0%, #425C25 100%);
    color: #ffffff;
    padding: 0.85rem 1.5rem;
    border-radius: 10px;
    text-decoration: none;
    font-weight: 600;
    font-size: 0.9rem;
    text-align: left;
    transition: all 0.25s ease;
    font-family: "Adelle", Georgia, serif;
  }

  .footer-cta-btn:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 20px rgba(66, 92, 37, 0.2);
  }

  .footer-bottom {
    border-top: 2px solid #9F5818;
    padding: 1.5rem 0;
  }

  .footer-bottom-content {
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 1rem;
  }

  .copyright {
    margin: 0;
    color: #9F5818;
    font-size: 0.85rem;
  }

  .legal-links {
    display: flex;
    align-items: center;
    gap: 1.75rem;
    flex-wrap: wrap;
  }

  .legal-links a {
    color: #9F5818;
    text-decoration: none;
    font-size: 0.85rem;
    transition: color 0.25s ease;
  }

  .legal-links a:hover {
    color: #425C25;
  }

  @media (max-width: 1024px) {
    .footer-content {
      grid-template-columns: 1fr 1fr 1fr;
    }

    .footer-brand {
      grid-column: 1 / -1;
      max-width: 100%;
    }
  }

  @media (max-width: 640px) {
    .footer-content {
      grid-template-columns: 1fr 1fr;
      gap: 2rem;
    }

    .footer-brand {
      grid-column: 1 / -1;
    }

    .footer-bottom-content {
      flex-direction: column;
      text-align: center;
    }

    .legal-links {
      justify-content: center;
    }
  }
</style>
