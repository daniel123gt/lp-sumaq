          <li><a href="/blog">Sostenibilidad</a></li>
          <li><a href="/blog">Tecnología</a></li>
          <li><a href="/blog">Cultivos</a></li>
          <li><a href="/blog">Consejos</a></li>
          <li><a href="/blog">Noticias</a></li>
        </ul>
      </div>

      <div class="footer-section">
        <h4>PRODUCTOS</h4>
        <ul class="footer-links">
          <li><a href="/productos">Bioenergizantes</a></li>
