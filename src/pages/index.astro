---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from "../components/Header.astro";
import Hero from "../components/Hero.astro";
import About from "../components/About.astro";
import Products from "../components/Products.astro";
import Contact from "../components/Contact.astro";
import Footer from "../components/Footer.astro";
import SchemaOrg from "../components/SchemaOrg.astro";
---

<BaseLayout
	title="SUMAQ AGRO - Productos Biológicos para Agricultura Sostenible"
	description="SUMAQ AGRO ofrece productos biológicos de alta calidad para una agricultura sostenible. Fertilizantes, bioestimulantes y biocatalizadores naturales."
	keywords="agricultura, productos biológicos, fertilizantes, bioestimulantes, SUMAQ AGRO, agricultura sostenible"
	ogImage="/products/DIATOMAQ.webp"
>
	<SchemaOrg type="Organization" data={{}} />
	<SchemaOrg type="LocalBusiness" data={{}} />
	
	<Header />

	<main id="main-content" role="main">
		<Hero />

		<section class="home-about">
			<div class="container">
				<div class="section-header">
					<h2>Un nuevo emprendimiento con alma</h2>
					<p>Conoce nuestra historia y misión</p>
				</div>
				<div class="about-preview">
					<div class="about-content">
						<p>
							Tras años de experiencia profesional en el sector
							agrícola, Susan Gómez decidió crear Sumaq Agro; una
							empresa que une tecnología, respeto ambiental y
							empatía humana.
						</p>
						<div class="about-highlights">
							<div class="highlight-item">
								<span>Raíces Andinas</span>
							</div>
							<div class="highlight-item">
								<span>Sostenibilidad</span>
							</div>
							<div class="highlight-item">
								<span>Empatía humana</span>
							</div>
						</div>
						<a href="/nosotros" class="btn btn-primary"
							>Conoce nuestra historia</a
						>
					</div>
				</div>
			</div>
		</section>

		<section class="home-blog">
			<div class="container">
				<div class="section-header">
					<h2>Últimas noticias y consejos</h2>
					<p>
						Mantente informado sobre las últimas tendencias
						agrícolas
					</p>
				</div>
				<div class="blog-preview">
					<a href="/blog/diatomaq-ventajas-agricultura-moderna" class="blog-preview-card">
						<div class="blog-image">
							<img src="/notices/6-ventajas.svg" alt="6 Ventajas de Diatomaq en la agricultura" loading="lazy" />
						</div>
						<h3>6 Ventajas de Diatomaq en la agricultura</h3>
						<p>
							Descubre las ventajas del Diatomaq, un producto natural
							para el control de plagas y mejora del suelo
						</p>
					</a>
					<div class="blog-preview-card">
						<div class="blog-image">
							<img src="/notices/mas-articulos.svg" alt="Más artículos próximamente" loading="lazy" />
						</div>
						<h3>Más Artículos próximamente</h3>
						<p>
							Estamos preparando más contenido valioso sobre
							agricultura sostenible
						</p>
					</div>
					<div class="blog-preview-card">
						<div class="blog-image">
							<img src="/notices/consejos-cultivos.svg" alt="Consejos de cultivo" loading="lazy" />
						</div>
						<h3>Consejos de cultivo</h3>
						<p>Guías prácticas para mejorar tus cultivos de forma natural</p>
					</div>
					<div class="blog-preview-card">
						<div class="blog-image">
							<img src="/notices/productos-biologicos.svg" alt="Productos biológicos" loading="lazy" />
						</div>
						<h3>Productos Biológicos</h3>
						<p>
							Información detallada sobre nuestros productos
							y sus beneficios
						</p>
					</div>
				</div>
				<div class="blog-cta">
					<a href="/blog" class="btn btn-primary"
						>Leer Más Artículos</a
					>
				</div>
			</div>
		</section>

		<section class="home-products">
			<div class="container">
				<div class="section-header">
					<h2>Productos destacados</h2>
					<p>
						Soluciones biológicas de alta calidad para maximizar tu rendimiento
					</p>
				</div>
				<div class="products-preview">
					<div class="product-preview-card product-booster">
						<div class="product-image">
							<img src="/newProducts/BOOSTER.svg" alt="BOOSTER" loading="lazy" />
						</div>
						<h3>BOOSTER</h3>
						<p>Revitalizador a base de algas marinas</p>
					</div>
					<div class="product-preview-card product-root">
						<div class="product-image">
							<img src="/newProducts/ROOT.svg" alt="ROOT" loading="lazy" />
						</div>
						<h3>ROOT</h3>
						<p>Bioestimulante y activador radicular</p>
					</div>
					<div class="product-preview-card product-arbolina">
						<div class="product-image">
							<img src="/newProducts/ARBOLINA.svg" alt="ARBOLINA" loading="lazy" />
						</div>
						<h3>ARBOLINA</h3>
						<p>Activador fisiológico para vitalidad</p>
					</div>
					<div class="product-preview-card product-actigen">
						<div class="product-image">
							<img src="/newProducts/ACTIGEN.svg" alt="ACTIGEN" loading="lazy" />
						</div>
						<h3>ACTIGEN</h3>
						<p>Más crecimiento, menos gasto energético</p>
					</div>
				</div>
				<div class="products-cta">
					<a href="/productos" class="btn btn-primary"
						>Ver catálogo completo</a
					>
				</div>
			</div>
		</section>

		<section class="home-contact">
			<div class="container">
				<div class="section-header">
					<h2 style="color: white !important;">
						¿Listo para Empezar?
					</h2>
					<p>Estamos aquí para ayudarte en tu proyecto agrícola</p>
				</div>
				<div class="contact-preview">
					<div class="contact-info">
						<div class="contact-item">
							<span class="contact-icon">📞</span>
							<span>+51982711622</span>
						</div>
						<div class="contact-item">
							<span class="contact-icon">✉️</span>
							<span>comercial@sumaqagro.pe</span>
						</div>
						<div class="contact-item">
							<span class="contact-icon">✉️</span>
							<span>sgomez@sumaqagro.pe</span>
						</div>
					</div>
					<div class="contact-actions">
						<a href="/contacto" class="btn btn-primary"
							>Contáctanos</a
						>
						<a href="/contacto" class="btn btn-outline"
							>Solicitar Cotización</a
						>
					</div>
				</div>
			</div>
		</section>

	</main>
	
	<Footer />

	<script>
		document.querySelectorAll('a[href^="#"]').forEach((anchor) => {
			anchor.addEventListener("click", (e: Event) => {
				e.preventDefault();
				const target = document.querySelector(
					(anchor as HTMLAnchorElement).getAttribute("href") ||
						"",
				);
				if (target) {
					target.scrollIntoView({
						behavior: "smooth",
						block: "start",
					});
				}
			});
		});

		const observerOptions = {
			threshold: 0.1,
			rootMargin: "0px 0px -50px 0px",
		};

		const observer = new IntersectionObserver((entries) => {
			entries.forEach((entry) => {
				if (entry.isIntersecting) {
					entry.target.classList.add("fade-in-up");
				}
			});
		}, observerOptions);

		document.querySelectorAll("section").forEach((section) => {
			observer.observe(section);
		});
	</script>
</BaseLayout>
